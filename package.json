{
  "name": "lop",
  "private": true,
  "version": "1.0.0",
  "description": "Private P2P Payments and Swaps on Stellar Testnet",
  "scripts": {
    "dev": "pnpm run --parallel dev",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "dev:indexer": "pnpm --filter indexer dev",
    "build": "pnpm --filter web build",
    "build:workspace": "pnpm -r build",
    "lint": "pnpm --filter web lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm -r --if-present run test",
    "ci:quality": "pnpm lint && pnpm format:check && pnpm typecheck",
    "ci:test": "pnpm test",
    "check:deploy-fee": "node scripts/deploy/check-fees.js",
    "debug:withdraw": "node scripts/debug/debug-withdraw.js",
    "deploy:all": "cmd /c scripts\\deploy\\deploy-all.bat",
    "deploy:contracts": "cmd /c scripts\\deploy\\deploy-contracts.bat",
    "init-shielded-pool": "node --env-file=.env scripts/init-shielded-pool.mjs"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@stellar/stellar-sdk": "^14.5.0",
    "prettier": "^3.4.2",
    "snarkjs": "^0.7.6"
  }
}
